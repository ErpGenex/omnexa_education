			"reqd": 1
		},
		{
			"fieldname": "company",
			"fieldtype": "Link",
			"label": "Company",
			"options": "Company",
			"reqd": 1
		},
		{
			"fieldname": "branch",
			"fieldtype": "Link",
			"label": "Branch",
			"options": "Branch",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "lms_provider",
			"fieldtype": "Select",
			"label": "LMS Provider",
			"options": "Moodle\nCanvas\nGoogle Classroom\nBlackboard\nCustom API",
			"reqd": 1
		},
		{
			"fieldname": "external_course_id",
			"fieldtype": "Data",
			"label": "External Course ID",
			"reqd": 1
		},
		{
			"fieldname": "sync_url",
			"fieldtype": "Data",
			"label": "Sync URL"
