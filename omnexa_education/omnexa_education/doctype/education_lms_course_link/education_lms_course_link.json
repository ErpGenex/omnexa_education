{
	"actions": [],
	"doctype": "DocType",
	"engine": "InnoDB",
	"module": "Omnexa Education",
	"name": "Education Lms Course Link",
	"permissions": [
		{
			"role": "System Manager",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 1,
			"submit": 1,
			"cancel": 1
		},
		{
			"role": "Education Manager",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 1,
			"submit": 1,
			"cancel": 1
		},
		{
			"role": "Education User",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 0,
			"submit": 1,
			"cancel": 0
		},
		{
			"role": "Teacher",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 0
		},
		{
			"role": "Desk User",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 0
