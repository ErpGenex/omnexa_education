{
	"actions": [],
	"doctype": "DocType",
	"engine": "InnoDB",
	"module": "Omnexa Education",
	"name": "Education Transcript Request",
	"permissions": [
		{
			"role": "System Manager",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 1,
			"submit": 1,
			"cancel": 1
		},
		{
			"role": "Education Manager",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 1,
			"submit": 1,
			"cancel": 1
		},
		{
			"role": "Education User",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 0,
			"submit": 1,
			"cancel": 0
		},
		{
			"role": "Teacher",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 0,
			"submit": 1,
			"cancel": 0
		},
		{
			"role": "Desk User",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 0
		}
	],
	"track_changes": 1,
	"autoname": "format:TRQ-{YYYY}-{#####}",
	"fields": [
		{
			"fieldname": "student",
			"fieldtype": "Link",
			"label": "Student",
			"options": "Education Student",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "institution",
			"fieldtype": "Link",
			"label": "Institution",
			"options": "Education Institution",
			"reqd": 1
		},
		{
			"fieldname": "company",
			"fieldtype": "Link",
			"label": "Company",
			"options": "Company",
			"reqd": 1
		},
		{
			"fieldname": "branch",
			"fieldtype": "Link",
			"label": "Branch",
			"options": "Branch",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "request_date",
			"fieldtype": "Date",
			"label": "Request Date",
			"default": "Today"
		},
		{
			"default": "Requested",
			"fieldname": "status",
			"fieldtype": "Select",
			"label": "Status",
			"options": "Requested\nIn Progress\nIssued\nRejected",
			"in_list_view": 1
		},
		{
			"fieldname": "purpose",
			"fieldtype": "Small Text",
			"label": "Purpose"
		},
		{
			"fieldname": "delivery_method",
			"fieldtype": "Select",
			"label": "Delivery",
			"options": "Pickup\nEmail\nCourier"
		}
	]
}
