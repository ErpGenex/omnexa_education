{
	"actions": [],
	"doctype": "DocType",
	"engine": "InnoDB",
	"module": "Omnexa Education",
	"name": "Education Announcement",
	"permissions": [
		{
			"role": "System Manager",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 1,
			"submit": 1,
			"cancel": 1
		},
		{
			"role": "Education Manager",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 1,
			"submit": 1,
			"cancel": 1
		},
		{
			"role": "Education User",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 0,
			"submit": 1,
			"cancel": 0
		},
		{
			"role": "Teacher",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 0
		},
		{
			"role": "Desk User",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 0
		},
		{
			"role": "Education Student Portal",
			"read": 1,
			"write": 0,
			"create": 0,
			"delete": 0
		},
		{
			"role": "Education Parent Portal",
			"read": 1,
			"write": 0,
			"create": 0,
			"delete": 0
		}
	],
	"track_changes": 1,
	"autoname": "format:ANN-{YYYY}-{#####}",
	"fields": [
		{
			"fieldname": "title",
			"fieldtype": "Data",
			"label": "Title",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "message",
			"fieldtype": "Text Editor",
			"label": "Message",
			"reqd": 1
		},
		{
			"fieldname": "institution",
			"fieldtype": "Link",
			"label": "Institution",
			"options": "Education Institution",
			"reqd": 1
		},
		{
			"fieldname": "company",
			"fieldtype": "Link",
			"label": "Company",
			"options": "Company",
			"reqd": 1
		},
		{
			"fieldname": "branch",
			"fieldtype": "Link",
			"label": "Branch",
			"options": "Branch",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "audience",
			"fieldtype": "Select",
			"label": "Audience",
			"options": "All\nStudents\nParents\nTeachers\nStaff",
			"default": "All"
		},
		{
			"default": "Administrative",
			"fieldname": "portal_channel",
			"fieldtype": "Select",
			"label": "Portal Channel",
			"options": "Administrative\nAcademic\nFinancial"
		},
		{
			"fieldname": "publish_date",
			"fieldtype": "Date",
			"label": "Publish Date",
			"default": "Today"
		}
	]
}
