{
	"actions": [],
	"doctype": "DocType",
	"engine": "InnoDB",
	"module": "Omnexa Education",
	"name": "Education Predictive Alert",
	"permissions": [
		{
			"role": "System Manager",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 1,
			"submit": 1,
			"cancel": 1
		},
		{
			"role": "Education Manager",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 1,
			"submit": 1,
			"cancel": 1
		},
		{
			"role": "Education User",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 0,
			"submit": 1,
			"cancel": 0
		},
		{
			"role": "Teacher",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 0
		},
		{
			"role": "Desk User",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 0
		}
	],
	"track_changes": 1,
	"autoname": "format:ALT-{YYYY}-{#####}",
	"fields": [
		{
			"fieldname": "student",
			"fieldtype": "Link",
			"label": "Student",
			"options": "Education Student",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "institution",
			"fieldtype": "Link",
			"label": "Institution",
			"options": "Education Institution",
			"reqd": 1
		},
		{
			"fieldname": "company",
			"fieldtype": "Link",
			"label": "Company",
			"options": "Company",
			"reqd": 1
		},
		{
			"fieldname": "branch",
			"fieldtype": "Link",
			"label": "Branch",
			"options": "Branch",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "alert_type",
			"fieldtype": "Select",
			"label": "Alert Type",
			"options": "At-Risk\nChronic Absence\nFee Default\nGrade Drop",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "score",
			"fieldtype": "Float",
			"label": "Risk Score"
		},
		{
			"fieldname": "details",
			"fieldtype": "Small Text",
			"label": "Details"
		},
		{
			"default": "Open",
			"fieldname": "status",
			"fieldtype": "Select",
			"label": "Status",
			"options": "Open\nAcknowledged\nClosed"
		}
	]
}
